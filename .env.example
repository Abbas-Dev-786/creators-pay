# ----------------------------------------------------------------------------
# CreatorPay environment. Copy to .env and fill in. Never commit .env.
# ----------------------------------------------------------------------------

# --- Chain ---
# 84532 = Base Sepolia (default, testnet demo). 8453 = Base mainnet.
NEXT_PUBLIC_CHAIN_ID=84532
# Optional overrides (defaults derived from chain id in src/lib/config.ts):
# NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# FACILITATOR_URL=https://tx-sentinel-base-sepolia.dev-api.cx.metamask.io/platform/v2/x402

# --- Supabase (Postgres + Storage) ---
# Postgres connection string used by Prisma (pooned connection for app runtime):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma Migrate (non-pooled):
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Service-role key — server-only, used to mint short-TTL signed download URLs.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Storage bucket holding paid product files (private bucket).
SUPABASE_PRODUCT_BUCKET="product-files"

# --- Venice AI ---
# Server-side Bearer key. AI products call Venice with this; ZDR models preferred.
VENICE_API_KEY="your-venice-api-key"
# VENICE_BASE_URL=https://api.venice.ai/api/v1

# --- Recurring billing session signer (F2) ---
# Private key of the session account that signs recurring x402 payments on behalf
# of subscribers (used by worker/billing-cron.ts and /api/ai/chat), bounded by
# each ERC-7715 permission. THREAT MODEL: compromise lets an attacker charge up to
# periodAmount per period until expiry, to the creator payTo only. In production
# hold this in a KMS / secret manager, NOT here.
# Generate a fresh keypair (BOTH vars must come from the SAME key):
#   node -e 'const {generatePrivateKey,privateKeyToAccount}=require("viem/accounts");const pk=generatePrivateKey();console.log("SESSION_PRIVATE_KEY="+pk);console.log("NEXT_PUBLIC_SESSION_ACCOUNT="+privateKeyToAccount(pk).address)'
SESSION_PRIVATE_KEY="0x..."
# Public address of SESSION_PRIVATE_KEY. Exposed to the client so ERC-7715
# subscription / AI grants delegate spending `to` this account. MUST match the
# address derived from SESSION_PRIVATE_KEY.
NEXT_PUBLIC_SESSION_ACCOUNT="0x..."

# --- Misc ---
# Public base URL of this app, used to build x402 resource URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
